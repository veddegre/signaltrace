{
    "title": "SignalTrace — Overview",
    "description": "Live 24-hour SOC display. No inputs — always shows the last 24 hours.",
    "inputs": {},
    "defaults": {
        "dataSources": {
            "ds.search": {
                "options": {
                    "queryParameters": {
                        "earliest": "-24h@h",
                        "latest": "now"
                    }
                }
            }
        }
    },
    "visualizations": {
        "viz_total_events": {
            "dataSources": { "primary": "ds_total_events" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#38bdf8",
                "showSparklineAreaGraph": true,
                "showSparklineTooltip": true,
                "sparklineAreaColor": "#38bdf8",
                "sparklineDisplay": "below",
                "sparklineStrokeColor": "#38bdf8",
                "trendColor": "#93c5fd",
                "trendDisplay": "absolute",
                "underLabel": "All SignalTrace events"
            },
            "title": "Total Events",
            "type": "splunk.singlevalue"
        },
        "viz_unique_ips": {
            "dataSources": { "primary": "ds_unique_ips" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#22c55e",
                "showSparklineAreaGraph": true,
                "showSparklineTooltip": true,
                "sparklineAreaColor": "#22c55e",
                "sparklineDisplay": "below",
                "sparklineStrokeColor": "#22c55e",
                "trendColor": "#86efac",
                "trendDisplay": "absolute",
                "underLabel": "Distinct source IPs"
            },
            "title": "Unique IPs",
            "type": "splunk.singlevalue"
        },
        "viz_unique_tokens": {
            "dataSources": { "primary": "ds_unique_tokens" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#a78bfa",
                "showSparklineAreaGraph": true,
                "showSparklineTooltip": true,
                "sparklineAreaColor": "#a78bfa",
                "sparklineDisplay": "below",
                "sparklineStrokeColor": "#a78bfa",
                "trendColor": "#c4b5fd",
                "trendDisplay": "absolute",
                "underLabel": "Distinct paths / tokens"
            },
            "title": "Unique Tokens",
            "type": "splunk.singlevalue"
        },
        "viz_bot_pct": {
            "dataSources": { "primary": "ds_bot_pct" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#f59e0b",
                "numberPrecision": 1,
                "trendColor": "#fcd34d",
                "trendDisplay": "off",
                "underLabel": "Classified as bot",
                "unit": "%",
                "unitPosition": "after"
            },
            "title": "Bot %",
            "type": "splunk.singlevalue"
        },
        "viz_avg_confidence": {
            "dataSources": { "primary": "ds_avg_confidence" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#06b6d4",
                "showSparklineAreaGraph": false,
                "trendDisplay": "off",
                "underLabel": "Avg confidence score"
            },
            "title": "Avg Confidence Score",
            "type": "splunk.singlevalue"
        },
        "viz_bot_count": {
            "dataSources": { "primary": "ds_bot_count" },
            "options": {
                "backgroundColor": "#111827",
                "majorColor": "#ef4444",
                "showSparklineAreaGraph": true,
                "showSparklineTooltip": true,
                "sparklineAreaColor": "#ef4444",
                "sparklineDisplay": "below",
                "sparklineStrokeColor": "#ef4444",
                "trendColor": "#fca5a5",
                "trendDisplay": "absolute",
                "underLabel": "Bot-classified hits"
            },
            "title": "Bot Events",
            "type": "splunk.singlevalue"
        },
        "viz_events_over_time": {
            "dataSources": { "primary": "ds_events_over_time" },
            "options": {
                "backgroundColor": "#111827",
                "dataValuesDisplay": "off",
                "seriesColors": ["#ef4444", "#f59e0b", "#38bdf8", "#22c55e"]
            },
            "title": "Events Over Time by Confidence Label",
            "type": "splunk.line"
        },
        "viz_confidence_mix": {
            "dataSources": { "primary": "ds_confidence_mix" },
            "options": {
                "backgroundColor": "#111827",
                "collapseLabel": "other",
                "collapseThreshold": 0.02,
                "seriesColors": ["#ef4444", "#f59e0b", "#38bdf8", "#22c55e"]
            },
            "title": "Confidence Label Distribution",
            "type": "splunk.pie"
        },
        "viz_top_ips": {
            "dataSources": { "primary": "ds_top_ips" },
            "options": {
                "backgroundColor": "#111827",
                "seriesColors": ["#38bdf8", "#6366f1", "#8b5cf6", "#ec4899"],
                "dataValuesDisplay": "all"
            },
            "title": "Top Source IPs",
            "type": "splunk.bar"
        },
        "viz_world_map": {
            "dataSources": { "primary": "ds_world_map" },
            "options": { "backgroundColor": "#111827" },
            "title": "Traffic by Country",
            "type": "splunk.table"
        },
        "viz_top_orgs": {
            "dataSources": { "primary": "ds_top_orgs" },
            "options": { "backgroundColor": "#111827" },
            "title": "Top ASN Organizations",
            "type": "splunk.table"
        },
        "viz_top_tokens": {
            "dataSources": { "primary": "ds_top_tokens" },
            "options": {
                "backgroundColor": "#111827",
                "seriesColors": ["#8b5cf6", "#ec4899", "#f43f5e", "#f97316"],
                "dataValuesDisplay": "all"
            },
            "title": "Top Tokens / Paths",
            "type": "splunk.bar"
        },
        "viz_top_bot_tokens": {
            "dataSources": { "primary": "ds_top_bot_tokens" },
            "options": {
                "backgroundColor": "#111827",
                "seriesColors": ["#ef4444", "#f97316", "#eab308", "#a855f7"],
                "dataValuesDisplay": "all"
            },
            "title": "Top Bot-Classified Tokens",
            "type": "splunk.bar"
        },
        "viz_confidence_reasons": {
            "dataSources": { "primary": "ds_confidence_reasons" },
            "options": {
                "backgroundColor": "#111827",
                "seriesColors": ["#a78bfa", "#38bdf8", "#22c55e", "#f59e0b", "#ef4444"],
                "dataValuesDisplay": "all"
            },
            "title": "Top Detection Signals",
            "type": "splunk.bar"
        },
        "viz_bot_by_country": {
            "dataSources": { "primary": "ds_bot_by_country" },
            "options": { "backgroundColor": "#111827" },
            "title": "Bot Traffic by Country",
            "type": "splunk.table"
        }
    },
    "dataSources": {
        "ds_total_events": {
            "name": "Total Events",
            "options": { "query": "index=security sourcetype=signaltrace | timechart span=15m count as total | table total _time" },
            "type": "ds.search"
        },
        "ds_unique_ips": {
            "name": "Unique IPs",
            "options": { "query": "index=security sourcetype=signaltrace | timechart span=15m dc(ip) as unique_ips | table unique_ips _time" },
            "type": "ds.search"
        },
        "ds_unique_tokens": {
            "name": "Unique Tokens",
            "options": { "query": "index=security sourcetype=signaltrace | timechart span=15m dc(token) as unique_tokens | table unique_tokens _time" },
            "type": "ds.search"
        },
        "ds_bot_pct": {
            "name": "Bot Percent",
            "options": { "query": "index=security sourcetype=signaltrace | stats count as total, count(eval(confidence_label=\"bot\" OR is_bot=1)) as bot_count | eval bot_pct=round((bot_count/total)*100,1) | table bot_pct" },
            "type": "ds.search"
        },
        "ds_avg_confidence": {
            "name": "Average Confidence Score",
            "options": { "query": "index=security sourcetype=signaltrace | stats avg(confidence_score) as avg_confidence | eval avg_confidence=round(avg_confidence,2)" },
            "type": "ds.search"
        },
        "ds_bot_count": {
            "name": "Bot Count",
            "options": { "query": "index=security sourcetype=signaltrace confidence_label=bot | timechart span=15m count as bot_events | table bot_events _time" },
            "type": "ds.search"
        },
        "ds_events_over_time": {
            "name": "Events Over Time",
            "options": { "query": "index=security sourcetype=signaltrace | eval confidence_label=coalesce(confidence_label,\"unknown\") | timechart span=15m count by confidence_label limit=10 useother=f" },
            "type": "ds.search"
        },
        "ds_confidence_mix": {
            "name": "Confidence Mix",
            "options": { "query": "index=security sourcetype=signaltrace | eval confidence_label=coalesce(confidence_label,\"unknown\") | stats count by confidence_label | sort - count" },
            "type": "ds.search"
        },
        "ds_top_ips": {
            "name": "Top IPs",
            "options": { "query": "index=security sourcetype=signaltrace | stats count by ip | sort - count | head 5" },
            "type": "ds.search"
        },
        "ds_world_map": {
            "name": "Traffic by Country",
            "options": { "query": "index=security sourcetype=signaltrace | eval ip_country=coalesce(ip_country,\"unknown\") | stats count by ip_country | sort - count | head 15" },
            "type": "ds.search"
        },
        "ds_top_orgs": {
            "name": "Top Organizations",
            "options": { "query": "index=security sourcetype=signaltrace | eval ip_org=coalesce(ip_org,\"unknown\") | stats count by ip_org | sort - count | head 5" },
            "type": "ds.search"
        },
        "ds_top_tokens": {
            "name": "Top Tokens",
            "options": { "query": "index=security sourcetype=signaltrace | eval token=coalesce(token,\"(null)\") | stats count by token | sort - count | head 5" },
            "type": "ds.search"
        },
        "ds_top_bot_tokens": {
            "name": "Top Bot Tokens",
            "options": { "query": "index=security sourcetype=signaltrace confidence_label=bot | eval token=coalesce(token,\"(null)\") | stats count by token | sort - count | head 5" },
            "type": "ds.search"
        },
        "ds_confidence_reasons": {
            "name": "Confidence Reasons",
            "options": { "query": "index=security sourcetype=signaltrace | makemv delim=\", \" confidence_reason | mvexpand confidence_reason | eval confidence_reason=coalesce(confidence_reason,\"unknown\") | stats count by confidence_reason | sort - count | head 5" },
            "type": "ds.search"
        },
        "ds_bot_by_country": {
            "name": "Bot Traffic by Country",
            "options": { "query": "index=security sourcetype=signaltrace confidence_label=bot | eval ip_country=coalesce(ip_country,\"unknown\") | stats count by ip_country | sort - count | head 10" },
            "type": "ds.search"
        }
    },
    "layout": {
        "globalInputs": [],
        "layoutDefinitions": {
            "layout_overview": {
                "options": {
                    "display": "auto-scale",
                    "height": 1080,
                    "width": 1920
                },
                "structure": [
                    { "item": "viz_total_events",     "position": { "h": 100, "w": 290, "x": 20,   "y": 20 }, "type": "block" },
                    { "item": "viz_unique_ips",        "position": { "h": 100, "w": 290, "x": 320,  "y": 20 }, "type": "block" },
                    { "item": "viz_unique_tokens",     "position": { "h": 100, "w": 290, "x": 620,  "y": 20 }, "type": "block" },
                    { "item": "viz_bot_pct",           "position": { "h": 100, "w": 290, "x": 920,  "y": 20 }, "type": "block" },
                    { "item": "viz_avg_confidence",    "position": { "h": 100, "w": 290, "x": 1220, "y": 20 }, "type": "block" },
                    { "item": "viz_bot_count",         "position": { "h": 100, "w": 290, "x": 1520, "y": 20 }, "type": "block" },
                    { "item": "viz_events_over_time",  "position": { "h": 260, "w": 1360, "x": 20,   "y": 140 }, "type": "block" },
                    { "item": "viz_confidence_mix",    "position": { "h": 260, "w": 510,  "x": 1390, "y": 140 }, "type": "block" },
                    { "item": "viz_top_ips",           "position": { "h": 230, "w": 700,  "x": 20,   "y": 420 }, "type": "block" },
                    { "item": "viz_world_map",          "position": { "h": 230, "w": 280,  "x": 740,  "y": 420 }, "type": "block" },
                    { "item": "viz_top_orgs",           "position": { "h": 230, "w": 840,  "x": 1040, "y": 420 }, "type": "block" },
                    { "item": "viz_top_tokens",         "position": { "h": 230, "w": 890,  "x": 20,   "y": 670 }, "type": "block" },
                    { "item": "viz_top_bot_tokens",     "position": { "h": 230, "w": 890,  "x": 930,  "y": 670 }, "type": "block" },
                    { "item": "viz_confidence_reasons", "position": { "h": 230, "w": 1080, "x": 20,   "y": 920 }, "type": "block" },
                    { "item": "viz_bot_by_country",     "position": { "h": 230, "w": 780,  "x": 1120, "y": 920 }, "type": "block" }
                ],
                "type": "absolute"
            }
        },
        "tabs": {
            "items": [
                { "label": "Overview", "layoutId": "layout_overview" }
            ]
        }
    }
}
