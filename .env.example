# SignalTrace Docker Environment Configuration
# Run ./setup.sh to generate this file automatically, or copy and fill in manually.
#
#   cp .env.example .env
#   vi .env

# ============================================================
# Required
# ============================================================

SIGNALTRACE_ADMIN_USERNAME=admin

# Port to expose SignalTrace on the host
SIGNALTRACE_PORT=80

# Bcrypt hash of the admin password.
# setup.sh generates this automatically.
# Or generate manually with:
#   php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT) . PHP_EOL;"
SIGNALTRACE_ADMIN_PASSWORD_HASH=

# Random salt for visitor fingerprint hashing.
# setup.sh generates this automatically.
# Or generate manually with: openssl rand -hex 64
SIGNALTRACE_VISITOR_HASH_SALT=

# ============================================================
# GeoIP enrichment (optional but recommended)
# Sign up free at https://www.maxmind.com
# ============================================================

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ============================================================
# Export API token (optional)
# Used for Splunk scripted inputs and other automation.
# Generate with: openssl rand -hex 32
# ============================================================

SIGNALTRACE_EXPORT_API_TOKEN=

# ============================================================
# Reverse proxy trust (optional)
# Set to the IP of your reverse proxy if running behind one.
# See the wiki for details: Deployment: Behind a Reverse Proxy
# ============================================================

SIGNALTRACE_TRUSTED_PROXY_IP=

# ============================================================
# Optional tuning
# These have sensible defaults — only set if you want to override.
# ============================================================

# Failed login attempts before lockout. Default: 5
# AUTH_MAX_FAILURES=5

# Lockout duration in seconds. Default: 900 (15 minutes)
# AUTH_LOCKOUT_SECS=900

# Your site's own domain. Requests to / with this in the Referer get a
# score penalty — helps catch crawler traffic. Leave blank to disable.
# SELF_REFERER_DOMAIN=

