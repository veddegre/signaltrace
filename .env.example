# SignalTrace Docker Environment Configuration
# Copy this file to .env and fill in your values before starting the container.
# This file must NOT be committed to Git — add it to .gitignore.
#
# Run setup.sh for a guided setup that generates all required secrets automatically.

# ── Admin Credentials ──────────────────────────────────────────────────────────

SIGNALTRACE_ADMIN_USERNAME="admin"

# Generate with:  php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT) . PHP_EOL;"
# Or let setup.sh generate it for you.
SIGNALTRACE_ADMIN_PASSWORD_HASH='replace-with-bcrypt-hash'

# ── Networking ─────────────────────────────────────────────────────────────────

# Host port SignalTrace listens on. Map to 80/443 or use a reverse proxy.
SIGNALTRACE_PORT="8080"

# ── Security ───────────────────────────────────────────────────────────────────

# Random salt for visitor fingerprint hashing.
# Generate with:  openssl rand -hex 64
# Do NOT change after deployment — it will invalidate all existing visitor hashes.
SIGNALTRACE_VISITOR_HASH_SALT="replace-with-random-secret"

# ── GeoIP Enrichment (recommended) ─────────────────────────────────────────────

# Free MaxMind account: https://www.maxmind.com
# Required for org, country, and ASN enrichment.
MAXMIND_ACCOUNT_ID=""
MAXMIND_LICENSE_KEY=""

# ── Export API Token (optional) ────────────────────────────────────────────────

# Used for Splunk scripted inputs and other automation.
# Generate with:  openssl rand -hex 32
# Use as:  Authorization: Bearer YOUR_TOKEN
# Leave blank to require admin Basic Auth for all export access.
SIGNALTRACE_EXPORT_API_TOKEN=""

# ── Reverse Proxy (optional) ───────────────────────────────────────────────────

# Set to the IP of your reverse proxy (nginx, Caddy, Traefik, Cloudflare, etc.)
# Without this, all traffic appears to come from the proxy's IP rather than real clients.
SIGNALTRACE_TRUSTED_PROXY_IP=""

# ── Rate Limiting (optional) ───────────────────────────────────────────────────

# Lock out an IP after this many consecutive failed login attempts.
AUTH_MAX_FAILURES="5"

# Lockout duration in seconds (default: 900 = 15 minutes).
AUTH_LOCKOUT_SECS="900"

# ── Scoring (optional) ─────────────────────────────────────────────────────────

# Your own domain. Requests arriving at / with this domain in the Referer header
# receive a small score penalty to help detect crawler traffic.
# Example: SELF_REFERER_DOMAIN="yourdomain.example"
SELF_REFERER_DOMAIN=""

# ── Cloudflare Access (optional) ───────────────────────────────────────────────

# Adds per-user identity and MFA in front of /admin using Cloudflare Zero Trust.
# See the Cloudflare Access wiki page for setup instructions before enabling.
# Leave CF_ACCESS_ENABLED blank or set to "false" to disable (default).
CF_ACCESS_ENABLED="false"
CF_ACCESS_AUD=""
CF_ACCESS_TEAM_DOMAIN=""

# ── Demo Mode (optional) ───────────────────────────────────────────────────────

# Set to "true" on a public demo instance to show the reset countdown banner
# and lock sensitive settings. Never enable on a production install.
# DEMO_ADMIN_USERNAME and DEMO_ADMIN_PASSWORD are display-only — they appear
# in the banner so visitors know the login. They do not set actual credentials.
DEMO_MODE="false"
DEMO_ADMIN_USERNAME=""
DEMO_ADMIN_PASSWORD=""

# ── Email Alerting ─────────────────────────────────────────────────────────────
#
# SMTP credentials are NOT stored in .env or the database for security reasons.
# They are defined as PHP constants in includes/config.local.php only.
# This keeps them out of the database even if an attacker reads it.
#
# For Docker installs, mount your config.local.php into the container:
#   volumes:
#     - ./config.local.php:/var/www/signaltrace/includes/config.local.php:ro
#
# Or define the constants inside the running container:
#   docker exec -it signaltrace bash
#   nano /var/www/signaltrace/includes/config.local.php
#
# The constants to add (see config.local.php.example for full documentation):
#   define('EMAIL_SMTP_HOST',       'smtp.yourdomain.example');
#   define('EMAIL_SMTP_PORT',       587);
#   define('EMAIL_SMTP_ENCRYPTION', 'tls');
#   define('EMAIL_SMTP_USER',       'signaltrace@yourdomain.example');
#   define('EMAIL_SMTP_PASS',       'your-smtp-password');
#   define('EMAIL_SMTP_FROM',       'signaltrace@yourdomain.example');
#
# After adding credentials, enable alerting and configure thresholds in Settings.
