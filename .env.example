# SignalTrace Docker Environment Configuration
# Copy this file to .env and fill in the values before running docker compose up.
#
#   cp .env.example .env
#   vi .env

# ============================================================
# Required
# ============================================================

SIGNALTRACE_ADMIN_USERNAME=admin

# Port to expose SignalTrace on the host
SIGNALTRACE_PORT=80

# Generate with:
#   php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT) . PHP_EOL;"
# Or if PHP isn't installed locally:
#   docker run --rm php:8.2-cli php -r "echo password_hash('yourpassword', PASSWORD_DEFAULT) . PHP_EOL;"
SIGNALTRACE_ADMIN_PASSWORD_HASH=

# Generate with:
#   openssl rand -hex 64
SIGNALTRACE_VISITOR_HASH_SALT=

# ============================================================
# GeoIP enrichment (optional but recommended)
# Sign up free at https://www.maxmind.com
# ============================================================

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ============================================================
# Export API token (optional)
# Used for Splunk scripted inputs and other automation.
# Generate with: openssl rand -hex 32
# ============================================================

SIGNALTRACE_EXPORT_API_TOKEN=

# ============================================================
# Reverse proxy trust (optional)
# Set to the IP of your reverse proxy if running behind one.
# See the wiki for details: Deployment: Behind a Reverse Proxy
# ============================================================

SIGNALTRACE_TRUSTED_PROXY_IP=
