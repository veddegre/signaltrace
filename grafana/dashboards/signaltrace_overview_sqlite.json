{
  "title": "SignalTrace Overview — SQLite",
  "uid": "signaltrace-sqlite",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["signaltrace", "security"],
  "panels": [
    {
      "id": 1,
      "title": "Total Events",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT COUNT(*) AS 'Total Events' FROM clicks WHERE clicked_at >= datetime('now', '-24 hours')"
      }]
    },
    {
      "id": 2,
      "title": "Bot Events",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT COUNT(*) AS 'Bot Events' FROM clicks WHERE confidence_label = 'bot' AND clicked_at >= datetime('now', '-24 hours')"
      }]
    },
    {
      "id": 3,
      "title": "Unique IPs",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT COUNT(DISTINCT ip) AS 'Unique IPs' FROM clicks WHERE clicked_at >= datetime('now', '-24 hours')"
      }]
    },
    {
      "id": 4,
      "title": "Avg Confidence Score",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "decimals": 1 }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT ROUND(AVG(confidence_score), 1) AS 'Avg Score' FROM clicks WHERE clicked_at >= datetime('now', '-24 hours')"
      }]
    },
    {
      "id": 5,
      "title": "Bot %",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "percent", "decimals": 1 }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT ROUND(100.0 * SUM(CASE WHEN confidence_label = 'bot' THEN 1 ELSE 0 END) / COUNT(*), 1) AS 'Bot %' FROM clicks WHERE clicked_at >= datetime('now', '-24 hours')"
      }]
    },
    {
      "id": 6,
      "title": "Confidence Label Distribution",
      "type": "piechart",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "bot" },          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "suspicious" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }] },
          { "matcher": { "id": "byName", "options": "likely-human" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#38bdf8" } }] },
          { "matcher": { "id": "byName", "options": "human" },        "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#22c55e" } }] }
        ]
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT confidence_label, COUNT(*) AS count FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') GROUP BY confidence_label ORDER BY count DESC"
      }]
    },
    {
      "id": 7,
      "title": "Events Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 20, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "bot" },          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "suspicious" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } }] },
          { "matcher": { "id": "byName", "options": "likely-human" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#38bdf8" } }] },
          { "matcher": { "id": "byName", "options": "human" },        "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#22c55e" } }] }
        ]
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT strftime('%Y-%m-%d %H:%M:00', clicked_at) AS time, confidence_label, COUNT(*) AS count FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') GROUP BY strftime('%Y-%m-%d %H:%M:00', clicked_at), confidence_label ORDER BY time ASC",
        "timeColumns": ["time"]
      }]
    },
    {
      "id": 8,
      "title": "Top Source IPs",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#38bdf8" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT ip, COUNT(*) AS hits FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') GROUP BY ip ORDER BY hits DESC LIMIT 10"
      }]
    },
    {
      "id": 9,
      "title": "Top Countries",
      "type": "barchart",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#a78bfa" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT COALESCE(ip_country, 'unknown') AS country, COUNT(*) AS hits FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') GROUP BY ip_country ORDER BY hits DESC LIMIT 10"
      }]
    },
    {
      "id": 10,
      "title": "Top ASN Organisations",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#f59e0b" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT COALESCE(ip_org, 'unknown') AS org, COUNT(*) AS hits FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') GROUP BY ip_org ORDER BY hits DESC LIMIT 10"
      }]
    },
    {
      "id": 11,
      "title": "Behavioral Signal Hits",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "orientation": "horizontal", "legend": { "displayMode": "hidden" } },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "#ef4444" } }
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT CASE WHEN confidence_reason LIKE '%burst_activity%' THEN 'Burst Activity' WHEN confidence_reason LIKE '%rapid_repeat%' THEN 'Rapid Repeat' WHEN confidence_reason LIKE '%fast_repeat%' THEN 'Fast Repeat' WHEN confidence_reason LIKE '%multi_token_scan%' THEN 'Multi-Token Scan' END AS signal, COUNT(*) AS hits FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') AND (confidence_reason LIKE '%burst_activity%' OR confidence_reason LIKE '%rapid_repeat%' OR confidence_reason LIKE '%fast_repeat%' OR confidence_reason LIKE '%multi_token_scan%') GROUP BY signal ORDER BY hits DESC"
      }]
    },
    {
      "id": 12,
      "title": "Recent Events",
      "type": "table",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "${DS_SQLITE}" },
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Label" }, "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "bot":          { "color": "#ef4444", "index": 0 } } },
              { "type": "value", "options": { "suspicious":   { "color": "#f59e0b", "index": 1 } } },
              { "type": "value", "options": { "likely-human": { "color": "#38bdf8", "index": 2 } } },
              { "type": "value", "options": { "human":        { "color": "#22c55e", "index": 3 } } }
            ]}
          ]}
        ]
      },
      "targets": [{
        "refId": "A",
        "queryText": "SELECT clicked_at AS 'Time', ip AS 'IP', COALESCE(ip_country,'?') AS 'Country', COALESCE(ip_org,'?') AS 'Org', confidence_label AS 'Label', confidence_score AS 'Score', token AS 'Token' FROM clicks WHERE clicked_at >= datetime('now', '-24 hours') ORDER BY clicked_at DESC LIMIT 50"
      }]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_SQLITE",
        "type": "datasource",
        "pluginId": "frser-sqlite-datasource",
        "label": "SQLite Datasource"
      }
    ]
  }
}
